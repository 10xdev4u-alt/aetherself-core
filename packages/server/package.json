{
  "name": "@aetherself/server",
  "version": "0.1.0",
  "type": "module",
  "private": true,
  "description": "AetherSelf local daemon — REST server for identity and memory",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "lint": "biome check src/",
    "test": "vitest run --reporter verbose",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@aetherself/protocol": "workspace:*",
    "@aetherself/crypto": "workspace:*",
    "hono": "^4.7.0",
    "@hono/node-server": "^1.13.0",
    "zod": "^3.25.0"
  },
  "devDependencies": {
    "typescript": "^5.8.0",
    "@types/node": "^22.0.0",
    "vitest": "^3.0.0"
  }
}
